services:
  fakegcs:
    image: fsouza/fake-gcs-server:latest
    command:
      - "-scheme=http"
      - "-port=4443"
      - "-log-level=debug"
      - "-event.bucket=common"
      - "-event.list=finalize,delete,metadataUpdate"
      - "-event.object-prefix=payload"
      - "-event.pubsub-project-id=fake-project"
      - "-event.pubsub-topic=my-topic"
    ports:
      - "4443:4443"
    environment:
      - PUBSUB_EMULATOR_HOST=httpdump:8080
    depends_on:
      - httpdump

  httpdump:
    image: daime/http-dump:latest
    ports:
      - "8080:8080"
